# Dame Luthas — Environment Variables
# Copy to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Management API PAT (apply migrations via MCP or Management API — not db push)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_ID=mygbzfvoctlvnxvzivso

# Site
NEXT_PUBLIC_SITE_URL=https://dameluthas.damieus.app
NEXT_PUBLIC_SITE_NAME=Dame Luthas

# Headless WordPress extract (dev-only scripts/wp/* — not used at runtime)
HEADLESS_MODE=snapshot
WP_HEADLESS_GRAPHQL_URL=http://dameluthas.local/graphql
# Absolute path to Local WP `app/public` — required for assets:convert only (not bundled).
LOCAL_WP_PUBLIC_PATH=/Users/dame/management-git/dame-luthas-app/local-wp/app/public

# Resend (contact form — server only)
# RESEND_API_KEY=re_...
# RESEND_FROM=Dame Luthas <hello@damieus.com>
# CONTACT_TO=dameluthas@gmail.com

# Vercel (pinned — matches .codebase-manifest.json; IDs are not secrets)
VERCEL_PROJECT_ID=prj_SF0avm0b1fTz5sWtyRdsaoG1hLtv
VERCEL_ORG_ID=team_gDyS6wIPTEdeuMu1PVvorxXx
VERCEL_PROJECT_NAME=dame-luthas-app
VERCEL_SCOPE=dame-luthas

# After `vercel env pull .env.local --yes`, re-merge repo-pinned keys from this file
# (Vercel CLI overwrites the file — keep Supabase Next.js + site + Resend below in .env.local)

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
