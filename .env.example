# Dame Luthas — Environment Variables
# Copy to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://dame-luthas.damieus.app
NEXT_PUBLIC_SITE_NAME=Dame Luthas

# Headless WordPress extract (dev-only scripts/wp/* — not used at runtime)
HEADLESS_MODE=snapshot
WP_HEADLESS_GRAPHQL_URL=http://dameluthas.local/graphql
# Absolute path to Local WP `app/public` — required for assets:convert only (not bundled).
LOCAL_WP_PUBLIC_PATH=/Users/dame/management-git/dame-luthas-app/local-wp/app/public

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
