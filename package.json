{
  "name": "dame-luthas-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "npx tsx scripts/wp/ensure-migrated-content.mts",
    "start": "next start",
    "lint": "eslint",
    "wp:snapshot": "npx tsx scripts/wp/build-snapshot.mts",
    "wp:migrate": "npx tsx scripts/wp/migrate-content.mts",
    "wp:sync-local": "npx tsx scripts/wp/sync-local-wp-path.mts",
    "wp:build-content": "npm run wp:snapshot && npm run wp:migrate",
    "wp:build-live": "npm run wp:extract-live && npm run wp:snapshot && npm run wp:migrate",
    "wp:pilot": "npm run wp:build-content && npm run dev",
    "wp:verify": "npx tsx scripts/wp/verify-headless.mts",
    "wp:install-graphql": "npx tsx scripts/wp/install-graphql-mu-plugin.mts",
    "wp:prepare": "npx tsx scripts/wp/prepare-backup.mts",
    "wp:extract": "npx tsx scripts/wp/extract-content.mts",
    "wp:map": "npx tsx scripts/wp/map-to-supabase.mts",
    "wp:screenshots": "npx tsx scripts/wp/capture-screenshots.mts",
    "wp:screenshots:next": "npx tsx scripts/wp/capture-next-screenshots.mts",
    "thegem:audit-css": "npx tsx scripts/thegem/audit-css-manifest.mts",
    "wp:probe-schema": "npx tsx scripts/wp/probe-schema.mts",
    "wp:extract-content": "npx tsx scripts/wp/extract-wp-content.mts",
    "wp:copy-assets": "npx tsx scripts/wp/copy-wp-assets.mts",
    "wp:sync-media": "echo 'deprecated: use npm run assets:convert' && exit 1",
    "assets:convert": "npx tsx scripts/media/convert-wp-assets.mts",
    "assets:copy-portfolio-video": "npx tsx scripts/media/copy-portfolio-video.mts",
    "assets:verify-bindings": "npx tsx scripts/media/verify-asset-bindings.mts",
    "assets:rebuild-manifest": "npx tsx scripts/media/rebuild-manifest-from-disk.mts",
    "assets:pipeline": "npm run assets:convert && npm run assets:copy-portfolio-video && npm run assets:rebuild-manifest && npm run assets:verify-bindings",
    "wp:codegen": "npm run wp:extract-content && npm run assets:convert",
    "wp:extract-design-system": "npx tsx scripts/wp/extract-design-system.mts",
    "test:parity": "playwright test e2e/parity.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test e2e/route-health.spec.ts e2e/browser-devtools.spec.ts e2e/navigation.spec.ts --grep @critical",
    "test:e2e:ui": "playwright test --ui",
    "test:devtools": "playwright test e2e/browser-devtools.spec.ts",
    "discover:routes": "npx tsx scripts/e2e/discover-routes.mts",
    "ci:parity": "npx tsx scripts/run-ci-parity.mts",
    "wp:visual-parity-audit": "npx tsx scripts/wp/visual-parity-audit.mts",
    "wp:audit-source": "npx tsx scripts/wp/audit-wp-source.mts",
    "wp:audit-full": "npx tsx scripts/wp/audit-wp-full.mts",
    "wp:verify-widget-census": "npx tsx scripts/wp/verify-widget-census.mts",
    "verify:public-routes": "npx tsx scripts/wp/verify-public-routes.mts",
    "wp:verify-custom-menus": "npx tsx scripts/wp/verify-custom-menus.mts",
    "deploy:staging": "npx tsx scripts/deploy-vercel.mts preview",
    "deploy:prod": "npx tsx scripts/deploy-vercel.mts production",
    "wp:extract-live": "WP_HEADLESS_GRAPHQL_URL=http://dameluthas.local/graphql npx tsx scripts/wp/extract-content.mts"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
